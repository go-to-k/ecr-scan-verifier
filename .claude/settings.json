{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/integ-docs-gate.sh",
            "if": "Bash(gh pr create*) or Bash(gh pr merge*)",
            "timeout": 10,
            "statusMessage": "Checking integ-docs marker..."
          }
        ]
      }
    ]
  }
}
